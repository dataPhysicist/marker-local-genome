{
  "name": "marker-local-genome",
  "productName": "Marker",
  "description": "Marker — local-first 23andMe-style genotype reading in your browser or Mac app.",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "private": false,
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/dataPhysicist/marker-local-genome.git"
  },
  "bugs": {
    "url": "https://github.com/dataPhysicist/marker-local-genome/issues"
  },
  "homepage": "https://github.com/dataPhysicist/marker-local-genome#readme",
  "keywords": [
    "genomics",
    "23andme",
    "privacy",
    "local-first",
    "pgx",
    "vite",
    "react"
  ],
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "electron:start": "npm run build && electron .",
    "dist:mac": "npm run build && electron-builder --mac dmg zip"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.11.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "typescript": "~5.6.3",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "io.github.marker.local-genome",
    "productName": "Marker",
    "copyright": "Copyright © Marker contributors",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.healthcare-fitness",
      "target": [
        "dmg",
        "zip"
      ],
      "identity": null,
      "gatekeeperAssess": false,
      "hardenedRuntime": false
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}
